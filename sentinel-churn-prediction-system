    "import pandas as pd\n",
    "import numpy as np\n",
    "import joblib\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.preprocessing import MinMaxScaler, OneHotEncoder\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "# ==========================================\n",
    "# 2. THE DATA PIPELINE PROCESS\n",
    "# ==========================================\n",
    "\n",
    "def build_model_pipeline(numeric_features, categorical_features):\n",
    " \n",
    "    # A. Numeric Transformer: Fill missing values with median, then scale 0 to 1\n",
    "    numeric_transformer = Pipeline(steps=[\n",
    "        ('imputer', SimpleImputer(strategy='median')),\n",
    "        ('scaler', MinMaxScaler())\n",
    "    ])\n",
    "\n",
    "    # B. Categorical Transformer: Fill missing with 'missing' label, then One-Hot Encode\n",
    "    categorical_transformer = Pipeline(steps=[\n",
    "        ('imputer', SimpleImputer(strategy='constant', fill_value='missing')),\n",
    "        ('onehot', OneHotEncoder(handle_unknown='ignore'))\n",
    "    ])\n",
    "\n",
    "    # C. ColumnTransformer: Glue the transformers together\n",
    "    preprocessor = ColumnTransformer(\n",
    "        transformers=[\n",
    "            ('num', numeric_transformer, numeric_features),\n",
    "            ('cat', categorical_transformer, categorical_features)\n",
    "        ])\n",
    "\n",
    "    # D. Full Pipeline: Preprocessing + Classifier\n",
    "    model_pipeline = Pipeline(steps=[\n",
    "        ('preprocessor', preprocessor),\n",
    "        ('classifier', LogisticRegression(class_weight='balanced'))\n",
    "    ])\n",
    "    \n",
    "    return model_pipeline\n",
    "\n",
    "# ==========================================\n",
    "# 3. EXECUTION BLOCK\n",
    "# ==========================================\n",
    "if __name__ == \"__main__\":\n",
    "\n",
    "    df = pd.read_csv('customer_data_large.csv')\n",
    "\n",
    "    num_cols = ['Monthly_Spend', 'Years', 'Age']\n",
    "    cat_cols = ['City']\n",
    "\n",
    "    model = build_model_pipeline(num_cols, cat_cols)\n",
    "\n",
    "    X = df[num_cols + cat_cols]\n",
    "    y = df['Churn']\n",
    "\n",
    "    model.fit(X, y)\n",
    "\n",
    "    prediction = model.predict(X)\n",
    "   \n",
    "    df['AI_Prediction'] = ['Will Leave' if p == 1 else 'Will Stay' for p in prediction]\n",
    "    print(df[['CustomerID', 'City', 'Churn', 'AI_Prediction']].head())\n",
