    "import pandas as pd\n",
    "import joblib\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import classification_report\n",
    "\n",
    "# 1. DATA LOADING & CLEANING\n",
    "df = pd.read_csv('customer_data_large_v2.csv')\n",
    "df['Join_Date'] = pd.to_datetime(df['Join_Date'])\n",
    "df['Years'] = df['Years'].fillna(df['Years'].median())\n",
    "df['Month'] = df['Join_Date'].dt.month\n",
    "\n",
    "# 2. FEATURE ENGINEERING\n",
    "# (Create your 'Spend_Per_Year' column here)\n",
    "df['Spend_Per_Year'] = (df['Monthly_Spend'] * 12) / df['Years']\n",
    "\n",
    "# 3. VISUAL INSIGHT (The \"Evidence\")\n",
    "# (Generate the Heatmap we made in Exercise 42)\n",
    "pivot = df.pivot_table(index='City', columns='Month', values='Churn', aggfunc='sum')\n",
    "sns.heatmap(pivot, annot=True, cmap='YlOrRd')\n",
    "\n",
    "# 4. PREDICTION (The \"AI Brain\")\n",
    "# (Load your 'universal.joblib' and predict on the 1,000 rows)\n",
    "model = joblib.load('universal_2.joblib')\n",
    "features = ['Monthly_Spend', 'Years', 'Age', 'City']\n",
    "X_test = df[features]\n",
    "predict = model.predict(X_test)\n",
    "df['Result'] = ['Will Leave' if p == 1 else 'Will Stay' for p in predict]\n",
    "\n",
    "# 5. THE \"ACTION\" LIST\n",
    "# (Filter for 'Will Leave' and save to Excel)\n",
    "to_save = df[df['Result'] == 'Will Leave']\n",
    "to_save.to_excel('Risky_Customer.xlsx', index=False)\n",
    "\n",
    "print(f\"🚀 Sentinel System Execution Complete. {len(to_save)} Lines exported to Excel\")\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.boxplot(x='Result', y='Monthly_Spend', data=df)\n",
    "plt.title('Spend Distribution: Stay vs Leave Prediction')\n",
    "plt.show()"
